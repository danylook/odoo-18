<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tpl_client_rate_form" model="ir.ui.view">
        <field name="name">tpl.3pl.client.rate.form</field>
        <field name="model">tpl.3pl.client.rate</field>
        <field name="arch" type="xml">
            <form string="Client Billing Rates">
                <sheet>
                    <div class="oe_title">
                        <label for="partner_id"/>
                        <h1><field name="partner_id" placeholder="Select client..."/></h1>
                    </div>
                    <group>
                        <group string="Inbound / Receiving">
                            <field name="inbound_enabled"/>
                            <field name="inbound_mode" invisible="not inbound_enabled"/>
                            <field name="inbound_product_id" invisible="not inbound_enabled"
                                   placeholder="Default: Handling Charges - Input"/>
                            <field name="inbound_price" invisible="not inbound_enabled"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="Outbound / Delivery">
                            <field name="outbound_enabled"/>
                            <field name="outbound_mode" invisible="not outbound_enabled"/>
                            <field name="outbound_product_id" invisible="not outbound_enabled"
                                   placeholder="Default: Handling Charges - Output"/>
                            <field name="outbound_price" invisible="not outbound_enabled"/>
                        </group>
                    </group>
                    <div class="alert alert-info mt-3" role="alert">
                        <strong>Storage fees</strong> are billed automatically each month
                        based on the <strong>Fee Rate</strong> set on each warehouse location
                        (Configuration &gt; Fee Rates). No extra setup needed here.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tpl_client_rate_list" model="ir.ui.view">
        <field name="name">tpl.3pl.client.rate.list</field>
        <field name="model">tpl.3pl.client.rate</field>
        <field name="arch" type="xml">
            <list string="Client Billing Rates">
                <field name="partner_id"/>
                <field name="inbound_enabled" string="Bill Inbound"/>
                <field name="inbound_mode" string="Inbound Mode"/>
                <field name="inbound_price" string="Inbound Price"/>
                <field name="outbound_enabled" string="Bill Outbound"/>
                <field name="outbound_mode" string="Outbound Mode"/>
                <field name="outbound_price" string="Outbound Price"/>
                <field name="currency_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="action_tpl_client_rate" model="ir.actions.act_window">
        <field name="name">Client Billing Rates</field>
        <field name="res_model">tpl.3pl.client.rate</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
