<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_tpl_3pl_api_key_list" model="ir.ui.view">
        <field name="name">tpl.3pl.api.key.list</field>
        <field name="model">tpl.3pl.api.key</field>
        <field name="arch" type="xml">
            <list string="API Keys">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="key" string="API Key"/>
                <field name="webhook_url"/>
                <field name="last_call"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_tpl_3pl_api_key_form" model="ir.ui.view">
        <field name="name">tpl.3pl.api.key.form</field>
        <field name="model">tpl.3pl.api.key</field>
        <field name="arch" type="xml">
            <form string="API Key">
                <header>
                    <button name="action_generate_key" type="object"
                            string="Regenerate Key" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="partner_id"/>
                        <field name="key" widget="CopyClipboardChar"/>
                        <field name="active"/>
                    </group>
                    <group string="Webhook">
                        <field name="webhook_url"/>
                        <field name="webhook_secret"/>
                    </group>
                    <group string="Info">
                        <field name="last_call"/>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tpl_3pl_api_keys" model="ir.actions.act_window">
        <field name="name">API Keys</field>
        <field name="res_model">tpl.3pl.api.key</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Add to existing 3PL menu -->
    <menuitem id="menu_tpl_3pl_api_keys"
              name="API Keys"
              parent="tpl_3pl_logistic.menu_tpl_config"
              action="action_tpl_3pl_api_keys"
              sequence="99"/>
</odoo>
