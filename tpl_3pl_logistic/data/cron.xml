<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="cron_create_stock_history" model="ir.cron">
        <field name="name">3PL: Create Daily Stock History Records</field>
        <field name="model_id" ref="base.model_res_lang"/>
        <field name="state">code</field>
        <field name="code">env['tpl.stock.history']._cron_daily_stock()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>

    <record id="cron_create_storage_invoices" model="ir.cron">
        <field name="name">3PL: Create Monthly Storage Invoices</field>
        <field name="model_id" ref="base.model_res_lang"/>
        <field name="state">code</field>
        <field name="code">env['tpl.stock.history']._cron_monthly_invoices()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
    </record>
</odoo>
