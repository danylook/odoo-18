<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Botón "Send to Robot" en el header de la MO.
    -->
    <record id="view_mrp_production_wf_ros2_button" model="ir.ui.view">
        <field name="name">mrp.production.wf.ros2.button</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_send_to_robot"
                        type="object"
                        string="Enviar a Robot"
                        class="btn-primary"
                        invisible="state not in ('confirmed', 'progress')"
                        groups="mrp.group_mrp_manager"/>
            </xpath>
        </field>
    </record>

    <!-- 3D Viewer page inject -->
    <record id="view_mrp_production_wf_ros2_3d" model="ir.ui.view">
        <field name="name">mrp.production.wf.ros2.3d</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Vista 3D — ROS2"
                      name="wf_ros2_3d"
                      invisible="not panel_section_id">
                    <widget name="wf_panel_3d_viewer"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
