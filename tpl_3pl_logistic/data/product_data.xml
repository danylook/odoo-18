<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="product_handling_input" model="product.template">
        <field name="name">Handling Charges - Input</field>
        <field name="type">service</field>
        <field name="invoice_policy">order</field>
        <field name="list_price">0.0</field>
        <field name="uom_id" ref="uom.product_uom_unit"/>
        <field name="uom_po_id" ref="uom.product_uom_unit"/>
        <field name="description_sale">Handling charge for receiving goods into warehouse</field>
    </record>

    <record id="product_handling_output" model="product.template">
        <field name="name">Handling Charges - Output</field>
        <field name="type">service</field>
        <field name="invoice_policy">order</field>
