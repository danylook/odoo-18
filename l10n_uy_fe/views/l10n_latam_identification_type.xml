        <field name="res_model">l10n_latam.document.type</field>
        <field name="context">{'search_default_localization': 1}</field>
    </record>

    <menuitem action="action_document_type_uruguay" id="menu_document_type_uruguay" sequence="5" parent="menu_dgi_config"/>


</odoo>
