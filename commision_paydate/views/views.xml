<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="view_custom_commission_settlement_line" model="ir.ui.view">
            <field name="name">custom.commission.settlement.line</field>
            <field name="model">commission.settlement.line</field>
            <field name="inherit_id" ref="commission_oca.view_settlement_line_tree"/>
            <field name="arch" type="xml">
                <field name="agent_id" position="after">
                    <field name="payment_date"/>
                </field>
            </field>
        </record>
        <record id="custom_view_settlement_line_tree_inherit" model="ir.ui.view">
            <field name="name">Custom Settlement lines</field>
            <field name="model">commission.settlement.line</field>
            <field name="inherit_id" ref="commission_oca.view_settlement_line_tree" />
            <field name="arch" type="xml">
            <xpath expr="field[@name='agent_id']" position="after">
                <field name="payment_date" />
            </xpath>
            </field>
        </record>
        <record id="view_custom_account_invoice_tree" model="ir.ui.view">
            <field name="name">custom.account.invoice.tree</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_out_invoice_tree"/>
            <field name="arch" type="xml">
                <field name="invoice_date_due" position="after">
                    <field name="payment_date"/>
                </field>
		<field name="name" position="after">
                    <field name="numero" />
                </field>
            </field>
        </record>
<!-- view_custom_account_payment_tree removed: ref field not in Odoo 18 -->
    </data>
</odoo>

