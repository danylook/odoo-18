<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_purchaseorder_inherit" inherit_id="purchase.report_purchaseorder_document">
        <xpath expr="//th[@name='th_description']" position="before">
            <t t-if="o.is_image_true">
                <th><strong>Image</strong></th>
            </t>
        </xpath>
        <xpath expr="//t[@t-foreach='o.order_line']/tr/t[@t-if='not line.display_type']/td[1]" position="before">
            <t t-if="o.is_image_true">
                <td style="height:40px !important;width:40px !important;">
                    <span t-field="line.order_line_image" t-options='{"widget": "image"}'/>
                </td>
            </t>
        </xpath>
    </template>
</odoo>
