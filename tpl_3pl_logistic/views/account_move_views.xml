<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action: 3PL client invoices (out_invoice for tpl_is_client partners) -->
    <record id="action_tpl_invoices" model="ir.actions.act_window">
        <field name="name">3PL Invoices</field>
        <field name="res_model">account.move</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('move_type', '=', 'out_invoice'), ('partner_id.tpl_is_client', '=', True)]</field>
        <field name="context">{'default_move_type': 'out_invoice'}</field>
    </record>

</odoo>
