<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_product_form_view_inherit_model_viewer" model="ir.ui.view">
        <field name="name">product.product.view.form.inherit.model.viewer.widget</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="3D Model Viewer" name="viewer">
                    <div id="3d_model_div" class="3d_model_viewer"/>
                    <field name="model_3d" string="Product Variant" widget="3D_widget"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
