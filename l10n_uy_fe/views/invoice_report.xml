<odoo>
    <template id="qr_fe_uy_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@class='page']/h2" position="replace">
            <h5>
                <t t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Factura Crédito</t>
                <t t-if="o.move_type == 'out_invoice' and o.state == 'draft'">Factura Borrador</t>
                <t t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Factura Cancelada</t>
                <t t-if="o.move_type == 'out_refund'">Nota de Crédito</t>
                <t t-if="o.move_type == 'in_refund'">Nota de Crédito de Proveedor</t>
                <t t-if="o.move_type == 'in_invoice'">Factura de Crédito</t>
                <t t-if="o.name != '/'">
                    <span t-field="o.name"/>
                </t>
            </h5>
        </xpath>

        <xpath expr="//address" position="attributes">
            <attribute name="style">font-size: 10px;</attribute>
        </xpath>

        <xpath expr="//div[@class='page']" position="attributes">
            <attribute name="style">font-size: 10px;</attribute>
        </xpath>

        <xpath expr="//table[@name='invoice_line_table']" position="attributes">
            <attribute name="style">font-size: 10px; padding: 0; margin-top: 1px; margin-bottom: 1px;</attribute>
        </xpath>

        <xpath expr="//div[@id='informations']" position="inside">
            <div class="col-auto col-3 mw-100 mb-2" t-if="o.currency_id" name="moneda">
                <strong>Moneda:</strong>
                <p class="m-0" t-field="o.currency_id.name"/>
            </div>
        </xpath>

        <xpath expr="//div[@id='qrcode']" position="replace">
            <div class="row" style="font-size: 10px;">
                <div class="col-md-5">
                    <div id="qrcode" style="display: 100%;">
                        <img class="border border-dark rounded"
                            height="120" width="120"
                            align="right" style='margin: 0px;padding-top:0px; background-color: gray;'
                            t-att-src="'data:image/png;base64,%s' % to_text(o.qr_code)"/>
                        <span t-field="o.footer_line"/>
                    </div>
                </div>
            </div>
            <div class="row" id="extra_footer_line" style="font-size: 10px;">
                <div class="col-md-12">
                    <span t-field="o.extra_footer_line"/>
                </div>
            </div>
        </xpath>
    </template>
</odoo>
