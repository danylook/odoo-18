<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_tpl_client_config_form" model="ir.ui.view">
    <field name="name">tpl.client.config.form</field>
    <field name="model">tpl.client.config</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <group string="Identity">
              <field name="name"/>
              <field name="active"/>
              <field name="owner_partner_id"/>
            </group>
            <group string="Connection">
              <field name="client_url"/>
              <field name="client_db"/>
              <field name="client_user"/>
              <field name="client_password" password="True"/>
            </group>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_tpl_client_config_list" model="ir.ui.view">
    <field name="name">tpl.client.config.list</field>
    <field name="model">tpl.client.config</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="owner_partner_id"/>
        <field name="client_url"/>
        <field name="client_db"/>
        <field name="active"/>
      </list>
    </field>
  </record>

  <record id="action_tpl_client_config" model="ir.actions.act_window">
    <field name="name">3PL Client Connections</field>
    <field name="res_model">tpl.client.config</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_tpl_back_sync_root"
            name="3PL Client Connections"
            parent="stock.menu_warehouse_config"
            action="action_tpl_client_config"
            sequence="99"/>
</odoo>
