<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_stock_picking_back_sync_buttons" model="ir.ui.view">
    <field name="name">stock.picking.back.sync.buttons</field>
    <field name="model">stock.picking</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="arch" type="xml">
      <xpath expr="//header" position="inside">
        <button name="action_retry_back_sync"
                string="Retry 3PL Sync"
                type="object"
                class="btn-warning"
                invisible="state != 'done'"/>
      </xpath>
    </field>
  </record>
</odoo>
