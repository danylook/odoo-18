<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="l10n_uy_fe_view_move_form" model="ir.ui.view">
        <field name="name">l10n_uy_fe.view.move.form</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="forma_pago"/>
            </xpath>

            <xpath expr="//field[@name='line_ids']/list/field[@name='account_id']" position="after">
                <field name="indicador_facturacion" optional="hide"/>
            </xpath>

            <xpath expr="//field[@name='line_ids']/form/group/field[@name='currency_id']" position="after">
                <field name="indicador_facturacion"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="DGI">
                    <group string="Documentos relacionados">
                        <field name="related_invoices_ids" widget="many2many"/>
                    </group>
                    <group string="Web Service">
                        <field name="token" readonly="1"/>
                        <field name="payload" readonly="1"/>
                        <field name="biller_id" readonly="1"/>
                        <field name="serie" readonly="1"/>
                        <field name="numero" readonly="1"/>
                        <field name="biller_hash" readonly="1"/>
                        <field name="fe_qr_url" readonly="1"/>
                        <field name="comprobante_dgi_pdf" widget="binary" readonly="1"/>
                        <field name="qr_code" readonly="1"/>
                    </group>
                    <group string="CAE">
                        <field name="tot_iva_tasa_min" readonly="1"/>
                        <field name="tot_iva_tasa_base" readonly="1"/>
                        <field name="tot_iva_tasa_otra" readonly="1"/>
                        <field name="es_nota_ajuste" readonly="1"/>
                        <field name="cae_nro" readonly="1"/>
                        <field name="cae_inicio" readonly="1"/>
                        <field name="cae_fin" readonly="1"/>
                        <field name="cae_fecha_expiracion" readonly="1"/>
                    </group>
                </page>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="btn_pull_pdf" type="object" string="Obtener PDF"/>
                <button name="update_qr_code" type="object" string="Actualizar QR Code"/>
            </xpath>
        </field>
    </record>
</odoo>
