<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.second.currency.cost</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="account.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='group_multi_currency']" position="after">
                    <div class="row mt16" invisible="not group_multi_currency">
                        <label for="currency_cost_id" class="col-lg-3 o_light_label"/>
                        <field name="currency_cost_id" options="{'no_create': True, 'no_create_edit': True}"/>
                    </div>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
