<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_res_config_settings_wf_panel_manufacturing" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.wf.panel.manufacturing</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="mrp.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//block[@name='process_operations_setting_container']" position="inside">
                    <setting
                        id="wf_panel_cut_timing"
                        string=""
                        help="Define los tiempos planificados para estimar el costo horario de corte."
                        help_no_update="Define the planned times to estimate the hourly cutting cost."
                        string_no_update=""
                    >
                        <div class="row mt8">
                            <div class="col-12 col-lg-6">
                                <label for="wf_cut_length_minutes_per_piece" string="Minutos por pieza"/>
                                <field name="wf_cut_length_minutes_per_piece" class="oe_inline"/>
                            </div>
                            <div class="col-12 col-lg-6">
                                <label for="wf_cut_length_setup_minutes" string="Minutos de preparación"/>
                                <field name="wf_cut_length_setup_minutes" class="oe_inline"/>
                            </div>
                        </div>
                        <div class="row mt8">
                            <div class="col-12 col-lg-6">
                                <label for="wf_cut_width_minutes_per_piece" string="Minutos por pieza (ancho)"/>
                                <field name="wf_cut_width_minutes_per_piece" class="oe_inline"/>
                            </div>
                            <div class="col-12 col-lg-6">
                                <label for="wf_cut_width_setup_minutes" string="Minutos de preparación (ancho)"/>
                                <field name="wf_cut_width_setup_minutes" class="oe_inline"/>
                            </div>
                        </div>
                    </setting>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
