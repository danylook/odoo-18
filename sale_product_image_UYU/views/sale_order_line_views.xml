<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form" model="ir.ui.view">
        <field name="name">sale.order.view.form.inherit.sale.product.image.uyu</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']"
                   position="after">
                <field name="order_line_image"
                       widget="image"
                       style="height:30px;width:30px;"
                       readonly="1"
                       column_invisible="not parent.is_image_true"/>
            </xpath>
        </field>
    </record>
</odoo>
